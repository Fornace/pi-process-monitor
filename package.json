{
  "name": "pi-process-monitor",
  "version": "1.0.0",
  "description": "Non-blocking background watcher for pi (by Fornace) — start a process, SSH poll, or log tail and get pinged in-session the moment a milestone hits, a failure occurs, or the process dies. The pi equivalent of Claude Code's Monitor tool, with conditional delivery (no per-line LLM turns).",
  "type": "module",
  "license": "MIT",
  "author": "Francesco Frapporti <effedue@gmail.com>",
  "homepage": "https://github.com/Fornace/pi-process-monitor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fornace/pi-process-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/Fornace/pi-process-monitor/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "monitor",
    "watcher",
    "background",
    "long-running",
    "training",
    "ssh",
    "log-tail",
    "notifications",
    "claude-code",
    "ai",
    "agent"
  ],
  "files": [
    "extensions",
    "skills",
    "prompts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": ["./extensions"],
    "skills": ["./skills"],
    "prompts": ["./prompts"]
  },
  "scripts": {
    "test": "node test/load.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "engines": {
    "node": ">=20"
  }
}
